# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# AWS S3
S3_REGION=eu-north-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=...
S3_PREFIX=          # optional folder prefix, e.g. reports/

# Google Cloud Storage (HMAC keys) — leave blank if not used
GCS_BUCKET=
GCS_PREFIX=
GCS_ACCESS_KEY=
GCS_SECRET_KEY=
